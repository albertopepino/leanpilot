# ─────────────────────────────────────────────────
# LeanPilot Configuration
# Copy this file to .env and fill in real values
# NEVER commit the .env file to git
# ─────────────────────────────────────────────────

# Database (used by docker-compose)
POSTGRES_DB=leanpilot
POSTGRES_USER=leanpilot
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Backend secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Admin account (created on first run)
ADMIN_EMAIL=admin@leanpilot.io
ADMIN_PASSWORD=
FACTORY_NAME=My Factory

# AI Module (optional — leave empty to disable)
OPENAI_API_KEY=
AI_MODULE_ENABLED=true
AI_MODEL=gpt-4o

# Error monitoring (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=info

# Email (optional — leave empty for console logging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourfactory.com

# Redis (used by rate limiting + token blacklist)
REDIS_URL=redis://redis:6379/0

# Domain (for CORS and email links)
APP_URL=https://lean.autopilot.rs
CORS_ORIGINS=https://lean.autopilot.rs
NEXT_PUBLIC_API_URL=http://backend:8000
