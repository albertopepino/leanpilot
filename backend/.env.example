DATABASE_URL=postgresql+asyncpg://leanpilot:leanpilot@localhost:5432/leanpilot
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Domain
APP_URL=https://lean.autopilot.rs
CORS_ORIGINS=https://lean.autopilot.rs

# AI Module (optional - only needed for Pro/Enterprise)
OPENAI_API_KEY=
AI_MODULE_ENABLED=true
AI_MODEL=gpt-4o

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@autopilot.rs

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0
